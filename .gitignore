# Ignore entire .terraform directories
**/.terraform/
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
terraform.tfstate
terraform.tfstate.backup

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files (optional, but often excluded)
.terraform.lock.hcl

# Ignore plan files
*.plan

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db